{
  "name": "Review",
  "type": "object",
  "properties": {
    "provider_id": {
      "type": "string",
      "description": "ID of the service provider"
    },
    "booking_id": {
      "type": "string",
      "description": "ID of the associated booking"
    },
    "reviewer_name": {
      "type": "string",
      "description": "Name of the reviewer"
    },
    "reviewer_email": {
      "type": "string",
      "description": "Email of the reviewer"
    },
    "rating": {
      "type": "number",
      "description": "Rating from 1-5"
    },
    "comment": {
      "type": "string",
      "description": "Review comment"
    }
  },
  "required": [
    "provider_id",
    "rating"
  ]
}
